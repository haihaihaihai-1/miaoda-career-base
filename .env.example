# ============================================================================
# miaoda-career-base 环境变量模板（提交到 git，开发者复制为 .env 后填值）
# ============================================================================

# --- Dify AI ---
# Dify 服务地址，例如 https://api.dify.ai/v1 或自托管 http://your-host:5001/v1
VITE_DIFY_API_URL=https://api.dify.ai/v1
# Dify 应用 API Key（Dify 控制台 -> 应用 -> API 访问）
VITE_DIFY_API_KEY=

# --- Supabase ---
# 项目 URL
VITE_SUPABASE_URL=https://your-project.supabase.co
# anon (public) key —— 前端唯一可用密钥
VITE_SUPABASE_ANON_KEY=
# 注意：service_role key 必须只在服务端使用，禁止放入 VITE_* 任何变量

# --- 其他 ---
VITE_EXTERNAL_RESOURCE_URL=
